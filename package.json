{
  "name": "picarview-landing",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "preinstall": "node -e \"if (!process.env.npm_config_user_agent?.startsWith('pnpm/')) { console.error('This project requires pnpm 10.32.1.'); process.exit(1) }\"",
    "generate:manifests": "node scripts/generate-hero-manifest.mjs && node scripts/generate-project-manifest.mjs",
    "dev": "pnpm run generate:manifests && next dev",
    "build": "pnpm run generate:manifests && next build && opennextjs-cloudflare build --skipNextBuild",
    "build:cloudflare": "pnpm run build",
    "preview:cloudflare": "pnpm run build && opennextjs-cloudflare preview",
    "deploy:cloudflare": "pnpm run build && opennextjs-cloudflare deploy",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@gsap/react": "^2.1.0",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "clsx": "^2.1.0",
    "gsap": "^3.12.4",
    "lenis": "1.3.25",
    "lucide-react": "1.24.0",
    "next": "15.5.18",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "tailwind-merge": "^2.2.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.20.1",
    "@types/node": "^20",
    "@types/react": "19.1.16",
    "@types/react-dom": "19.1.9",
    "@types/three": "^0.160.0",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "15.5.18",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5",
    "wrangler": "4.111.0"
  }
}
